# Server Environment
NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://cdi_user:cdi_password@localhost:5432/cdi_db
SHADOW_DATABASE_URL=postgresql://cdi_user:cdi_password@localhost:5432/cdi_db_shadow

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cdi_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000
